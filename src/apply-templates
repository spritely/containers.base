#!/usr/bin/env bash
set -euo pipefail

# apply-templates: Apply multiple templates to a project from a YAML config.

CONFIG_DIR=".templates"

usage() {
    echo "Usage: apply-templates [--config-dir PATH]"
    echo ""
    echo "Apply templates defined in CONFIG_DIR/config.{yaml,yml} to the current project."
    echo ""
    echo "Options:"
    echo "  --config-dir PATH  Config directory (default: .templates)"
    echo "  --help             Show this help message"
    exit 0
}

# Find a config file with .yaml or .yml extension.
# Usage: find_config_file BASE_NAME  (e.g. "config" or "config.local")
# Sets REPLY to the found path, or empty string if not found.
# Errors if both extensions exist.
find_config_file() {
    local base="$CONFIG_DIR/$1"
    local yaml_file="$base.yaml"
    local yml_file="$base.yml"

    if [[ -f "$yaml_file" && -f "$yml_file" ]]; then
        echo "Error: Both $yaml_file and $yml_file exist. Use one or the other." >&2
        exit 1
    fi

    if [[ -f "$yaml_file" ]]; then
        REPLY="$yaml_file"
    elif [[ -f "$yml_file" ]]; then
        REPLY="$yml_file"
    else
        REPLY=""
    fi
}

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        --config-dir)
            CONFIG_DIR="$2"
            shift 2
            ;;
        --help)
            usage
            ;;
        *)
            echo "Error: Unknown argument '$1'" >&2
            echo "Run 'apply-templates --help' for usage." >&2
            exit 1
            ;;
    esac
done

find_config_file "config"
CONFIG_FILE="$REPLY"

if [[ -z "$CONFIG_FILE" ]]; then
    echo "Error: Config file not found in $CONFIG_DIR (expected config.yaml or config.yml)" >&2
    exit 1
fi

find_config_file "config.local"
CONFIG_LOCAL_FILE="$REPLY"

# Merge templates arrays from config and config.local (if it exists)
if [[ -n "$CONFIG_LOCAL_FILE" ]]; then
    RAW_TEMPLATES=$(yq eval-all -o=json '
        [select(fi == 0).templates[], select(fi == 1).templates[]]
    ' "$CONFIG_FILE" "$CONFIG_LOCAL_FILE")
else
    RAW_TEMPLATES=$(yq -o=json '.templates' "$CONFIG_FILE")
fi

# Recursively expand any { include: <file> } entries in the templates array.
# Included files must exist and must have a top-level 'templates' array.
expand_includes() {
    local json="$1"
    local result="[]"
    local count=$(echo "$json" | jq 'length')
    local j
    for ((j=0; j<count; j++)); do
        local entry=$(echo "$json" | jq ".[$j]")
        local include=$(echo "$entry" | jq -r '.include // ""')
        if [[ -n "$include" ]]; then
            local include_path="$CONFIG_DIR/$include"
            if [[ ! -f "$include_path" ]]; then
                echo "Error: Included config file not found: $include_path" >&2
                exit 1
            fi
            local included_json=$(yq -o=json '.templates // []' "$include_path")
            included_json=$(expand_includes "$included_json")
            result=$(jq -n --argjson a "$result" --argjson b "$included_json" '$a + $b')
        else
            result=$(jq -n --argjson a "$result" --argjson e "$entry" '$a + [$e]')
        fi
    done
    echo "$result"
}

MERGED_TEMPLATES=$(expand_includes "$RAW_TEMPLATES")

TEMPLATE_COUNT=$(echo "$MERGED_TEMPLATES" | jq 'length')

if [[ "$TEMPLATE_COUNT" -eq 0 ]]; then
    echo "No templates found in config."
    exit 0
fi

merge_json() {
    local base="$1"
    local overlay="$2"
    local tmp
    tmp=$(mktemp)
    jq -s '.[0] * .[1] | del(.. | nulls)' "$base" "$overlay" > "$tmp" && mv "$tmp" "$base" || rm -f "$tmp"
}

merge_yaml() {
    local base="$1"
    local overlay="$2"
    local tmp
    tmp=$(mktemp)
    yq eval-all '. as $item ireduce ({}; . * $item)' "$base" "$overlay" | yq 'del(.. | select(. == null))' > "$tmp" && mv "$tmp" "$base" || rm -f "$tmp"
}

merge_files() {
    local source_dir="$1"
    local target_dir="$2"

    while IFS= read -r -d '' file; do
        local rel="${file#"$source_dir"/}"
        local target_file="$target_dir/$rel"

        mkdir -p "$(dirname "$target_file")"

        # Check for XML merge directive (comment-based, extension-independent)
        if head -5 "$file" | grep -q '<!-- *merge:xml'; then
            [[ -f "$target_file" ]] || cp "$file" "$target_file"
            merge-xml "$target_file" "$file"
            continue
        fi

        if [[ -f "$target_file" ]]; then
            case "$rel" in
                *.json)
                    merge_json "$target_file" "$file"
                    continue
                    ;;
                *.yaml|*.yml)
                    merge_yaml "$target_file" "$file"
                    continue
                    ;;
            esac
        fi

        cp "$file" "$target_file"
    done < <(find "$source_dir" -path '*/.git' -prune -o -type f -print0)
}

apply_template_git() {
    local source="$1"
    local ref="$2"
    local target="$3"
    local path="$4"
    local strategy="${5:-overwrite}"

    local temp_dir
    temp_dir=$(mktemp -d)
    trap "rm -rf '$temp_dir'" RETURN

    if [[ -n "$ref" ]]; then
        git clone --branch "$ref" --depth 1 "$source" "$temp_dir/repo" 2>&1
    else
        git clone --depth 1 "$source" "$temp_dir/repo" 2>&1
    fi

    local source_dir="$temp_dir/repo"
    if [[ -n "$path" ]]; then
        source_dir="$source_dir/$path"
        if [[ ! -d "$source_dir" ]]; then
            echo "Error: Path '$path' does not exist in repository '$source'" >&2
            return 1
        fi
    fi

    mkdir -p "$target"
    if [[ "$strategy" == "merge" ]]; then
        merge_files "$source_dir" "$target"
    else
        tar -cf - --exclude='.git' -C "$source_dir" . | tar -xf - -C "$target"
    fi
}

apply_template_copy() {
    local source="$1"
    local _ref="$2" # unused for copy type
    local target="$3"
    local path="$4"
    local strategy="${5:-overwrite}"

    if [[ -n "$path" ]]; then
        source="$source/$path"
    fi

    if [[ ! -e "$source" ]]; then
        echo "Error: Source path does not exist: $source" >&2
        return 1
    fi

    mkdir -p "$target"
    if [[ "$strategy" == "merge" ]]; then
        merge_files "$source" "$target"
    else
        tar -cf - --exclude='.git' -C "$source" . | tar -xf - -C "$target"
    fi
}

apply_template_copier() {
    local name="$1"
    local source="$2"
    local ref="$3"
    local target="$4"
    local path="$5"

    # Answers file is stored in the target directory with a per-template name.
    # This allows multiple copier templates to target the same directory.
    # The path must be relative to the target (copier requirement).
    local answers_file
    local config_dir_abs=$(realpath -m "$CONFIG_DIR")
    local target_abs=$(realpath -m "$target")
    if [[ "$config_dir_abs/" == "$target_abs/"* ]]; then
        answers_file="${config_dir_abs#"$target_abs/"}/.copier-answers.${name}.yaml"
    else
        answers_file=".copier-answers.${name}.yaml"
    fi
    local answers_abs="$target_abs/$answers_file"
    local copier_temp_dir=""

    mkdir -p "$target"
    mkdir -p "$config_dir_abs"

    trap '[[ -n "$copier_temp_dir" ]] && rm -rf "$copier_temp_dir"' RETURN

    if [[ -n "$path" ]]; then
        # copier has no --subdir flag, so clone and point copier at the local subdir.
        # We always re-copy (not update) since copier update cannot change _src_path.
        copier_temp_dir=$(mktemp -d)

        if [[ -n "$ref" ]]; then
            git clone --branch "$ref" --depth 1 "$source" "$copier_temp_dir/repo" 2>&1
        else
            git clone --depth 1 "$source" "$copier_temp_dir/repo" 2>&1
        fi

        local template_source="$copier_temp_dir/repo/$path"
        if [[ ! -d "$template_source" ]]; then
            echo "Error: Path '$path' does not exist in repository '$source'" >&2
            return 1
        fi

        if [[ -f "$answers_abs" ]]; then
            copier copy --defaults --overwrite --trust -a "$answers_file" "$template_source" "$target"
        else
            copier copy --overwrite --trust -a "$answers_file" "$template_source" "$target"
        fi

        # Patch _src_path to the original URL so the answers file doesn't point at the temp dir.
        if [[ -f "$answers_abs" ]]; then
            yq -i "._src_path = \"$source\"" "$answers_abs"
        else
            echo "Warning: copier did not create an answers file for '$name'." >&2
        fi
    else
        local ref_args=()
        [[ -n "$ref" ]] && ref_args=(--vcs-ref "$ref")

        if [[ -f "$answers_abs" ]]; then
            copier update --defaults --trust -a "$answers_file" "${ref_args[@]}" "$target"
        else
            copier copy --overwrite --trust -a "$answers_file" "${ref_args[@]}" "$source" "$target"
        fi
    fi
}

for ((i=0; i<TEMPLATE_COUNT; i++)); do
    eval "$(echo "$MERGED_TEMPLATES" | jq -r ".[$i] | \
        \"name=\" + (.name // \"\" | @sh),
        \"source=\" + (.source // \"\" | @sh),
        \"type=\" + (.type // \"git\" | @sh),
        \"ref=\" + (.ref // \"\" | @sh),
        \"target=\" + (.target // \".\" | @sh),
        \"path=\" + (.path // \"\" | @sh),
        \"strategy=\" + (.strategy // \"overwrite\" | @sh),
        \"run=\" + (.run // \"\" | @sh)
    ")"

    if [[ "$name" == "null" || -z "$name" ]]; then
        echo "Error: Template at index $i is missing required 'name' field" >&2
        exit 1
    fi
    if [[ "$source" == "null" || -z "$source" ]]; then
        echo "Error: Template '$name' is missing required 'source' field" >&2
        exit 1
    fi

    if [[ "$strategy" != "overwrite" && "$strategy" != "merge" ]]; then
        echo "Error: Unknown strategy '$strategy' for template '$name'. Must be 'overwrite' or 'merge'." >&2
        exit 1
    fi

    # Make target an absolute path if it's relative
    if [[ "$target" != /* ]]; then
        target="$(pwd)/$target"
    fi

    if [[ "$strategy" != "overwrite" ]]; then
        echo "Applying $name ($type, strategy: $strategy) from $source..."
    else
        echo "Applying $name ($type) from $source..."
    fi

    if [[ "$strategy" != "overwrite" && "$type" == "copier" ]]; then
        echo "Warning: 'strategy' is not supported for copier templates. Ignoring for '$name'." >&2
    fi

    case "$type" in
        git)
            apply_template_git "$source" "$ref" "$target" "$path" "$strategy"
            ;;
        copy)
            apply_template_copy "$source" "$ref" "$target" "$path" "$strategy"
            ;;
        copier)
            apply_template_copier "$name" "$source" "$ref" "$target" "$path"
            ;;
        *)
            echo "Error: Unknown template type '$type' for template '$name'" >&2
            exit 1
            ;;
    esac

    if [[ -n "$run" ]]; then
        echo "  Running: $run"
        (cd "$target" && bash -c "$run")
    fi

    echo "  Done."
done

echo "All templates applied successfully."
